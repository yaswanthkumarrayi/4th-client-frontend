# Backend API URL - Update with your production API
VITE_API_URL=https://api.samskruthi.example.com/api

# Razorpay Public Key (KEY_ID only - NEVER expose SECRET KEY)
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXX

# Firebase Configuration (PUBLIC - safe to expose in code)
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID
